{
  "name": "smart_agri_web_r6",
  "displayName": "Smart Agri IoT",
  "version": "0.1.1",
  "private": true,
  "devDependencies": {
    "esbuild": "^0.27.3"
  },
  "scripts": {
    "build": "esbuild app/javascript/*.* --bundle --sourcemap --format=esm --outdir=app/assets/builds --public-path=/assets --loader:.jsx=jsx",
    "build:css": "bunx @tailwindcss/cli -i ./app/assets/stylesheets/application.tailwind.css -o ./app/assets/builds/application.css --minify",
    "build:scss": "sass ./app/assets/stylesheets/application.bootstrap.scss:./app/assets/builds/application.css --no-source-map --style=compressed"
  },
  "dependencies": {
    "@hotwired/stimulus": "^3.2.2",
    "@hotwired/turbo-rails": "^8.0.23",
    "@popperjs/core": "^2.11.8",
    "@rails/actioncable": "^7.2.0",
    "@tailwindcss/cli": "^4.2.1",
    "bootstrap": "^5.3.3",
    "jquery": "^4.0.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "sass": "^1.83.0",
    "tailwindcss": "^4.2.1"
  }
}
